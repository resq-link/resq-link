{
  "expo": {
    "name": "RESQ-Link",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "scheme": "resqlink",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.tuguegarao.resqlink",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION"
      ],
      "package": "com.tuguegarao.resqlink"
    },
    "plugins": [
      [
        "expo-router",
        {
          "sitemap": false
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain"
        }
      ],
      "expo-audio",
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ],
      [
        "expo-video",
        { "supportsBackgroundPlayback": true, "supportsPictureInPicture": true }
      ],
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to report emergencies accurately.",
          "locationAlwaysPermission": "Allow $(PRODUCT_NAME) to use your location to report emergencies accurately.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to report emergencies accurately."
        }
      ]
    ],
    "web": {
      "bundler": "metro",
      "favicon": "./assets/images/favicon.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "apiUrl": "http://localhost:4000",
      "uiMode": false,
      "firebase": {
        "apiKey": "AIzaSyCj-lCXFkSzi2ahhj60ZDOdnRvCxQ1BRfA",
        "authDomain": "resqlink-eab64.firebaseapp.com",
        "projectId": "resqlink-eab64",
        "storageBucket": "resqlink-eab64.firebasestorage.app",
        "messagingSenderId": "829563426660",
        "appId": "1:829563426660:web:410a93234d941fc795cc71"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
