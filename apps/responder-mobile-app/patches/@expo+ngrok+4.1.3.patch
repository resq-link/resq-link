-const { defaults, validate, isRetriable } = require("./src/utils");
+const {
+  defaults,
+  validate,
+  isRetriable,
+  isTransientTunnelError,
+} = require("./src/utils");
 
 let processUrl = null;
 let ngrokClient = null;
@@ -19,7 +24,24 @@ async function connect(opts) {
     await setAuthtoken(opts);
   }
 
-  processUrl = await getProcess(opts);
+  let lastErr;
+  for (let attempt = 0; attempt < 8; attempt++) {
+    try {
+      processUrl = await getProcess(opts);
+      lastErr = null;
+      break;
+    } catch (e) {
+      lastErr = e;
+      if (!isTransientTunnelError(e) || attempt === 7) {
+        throw e;
+      }
+      await new Promise((r) =>
+        setTimeout(r, Math.min(500 + attempt * 500, 5000))
+      );
+    }
+  }
+  if (!processUrl) throw lastErr || new Error("ngrok process failed to start");
+
   ngrokClient = new NgrokClient(processUrl);
