diff --git a/node_modules/@expo/ngrok/src/utils.js b/node_modules/@expo/ngrok/src/utils.js
index 1c2288a..154fbc4 100644
--- a/node_modules/@expo/ngrok/src/utils.js
+++ b/node_modules/@expo/ngrok/src/utils.js
@@ -51,8 +51,25 @@ function isRetriable(err) {
   return notReady500 || notReady502 || notReady503;
 }
 
+/** Transient ngrok agent / network errors that often succeed on retry. */
+function isTransientTunnelError(err) {
+  if (!err) return false;
+  if (err.code === "ECONNREFUSED" || err.code === "ECONNRESET") return true;
+  const parts = [];
+  if (typeof err.message === "string") parts.push(err.message);
+  if (err.body) {
+    if (typeof err.body === "string") parts.push(err.body);
+    else if (typeof err.body.msg === "string") parts.push(err.body.msg);
+  }
+  const msg = parts.join(" ");
+  return /gone away|remote gone|failed to start tunnel|connection reset|ECONNREFUSED|ECONNRESET|ETIMEDOUT|socket hang up|EPIPE|ENOTFOUND|tls handshake|i\/o timeout|broken pipe|failed to connect/i.test(
+    msg
+  );
+}
+
 module.exports = {
   defaults,
   validate,
   isRetriable,
+  isTransientTunnelError,
 };
