     return response.public_url;
   } catch (err) {
-    if (!isRetriable(err) || retryCount >= 100) {
+    const retriable = isRetriable(err) || isTransientTunnelError(err);
+    if (!retriable || retryCount >= 100) {
       throw err;
     }
-    await new Promise((resolve) => setTimeout(resolve, 200));
+    const delay = isTransientTunnelError(err)
+      ? Math.min(400 + retryCount * 400, 10000)
+      : 200;
+    await new Promise((resolve) => setTimeout(resolve, delay));
     return connectRetry(opts, ++retryCount);
   }
 }
