# Mapbox Configuration
# Get your access token from https://account.mapbox.com/access-tokens/
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=

# Optional: Mapbox style (default: mapbox/streets-v12)
NEXT_PUBLIC_MAPBOX_STYLE=mapbox/streets-v12

# Server-only: Gemini API key for the dispatcher AI assistant.
# Do not prefix this with NEXT_PUBLIC_.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Server-only: Firebase Admin credentials for authenticated API routes.
# Use an absolute path locally, or FIREBASE_SERVICE_ACCOUNT_JSON in hosting.
GOOGLE_APPLICATION_CREDENTIALS=
FIREBASE_SERVICE_ACCOUNT_JSON=
