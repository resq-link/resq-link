{
  "name": "@packages/firebase",
  "version": "1.0.0",
  "description": "Shared Firebase package for RESCUE mobile apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./admin": "./dist/admin.js",
    "./civilian-auth": "./dist/civilian-auth.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "seed:incident-types": "ts-node scripts/seed-incident-type-rules.ts",
    "seed:civilians": "ts-node scripts/create-civilian-users.ts",
    "prepare": "npm run build"
  },
  "dependencies": {
    "firebase": "^12.11.0",
    "firebase-admin": "^10.3.0",
    "yn": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "dotenv": "^16.4.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "overrides": {
    "protobufjs": "6.11.6",
    "@grpc/proto-loader": {
      "protobufjs": "6.11.6"
    },
    "proto3-json-serializer": {
      "protobufjs": "6.11.6"
    },
    "google-gax": {
      "protobufjs": "6.11.6",
      "@grpc/proto-loader": {
        "protobufjs": "6.11.6"
      }
    }
  },
  "private": true
}
