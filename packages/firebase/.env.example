# Firebase Admin SDK - required for create-first-admin.ts and other admin scripts
# Get from: Firebase Console → Project Settings → Service Accounts → Generate new private key

# Option 1: Path to the downloaded JSON key file
GOOGLE_APPLICATION_CREDENTIALS=./service-account-key.json

# Option 2: The full JSON as a single line (escape quotes or use a tool to minify)
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project",...}

# Optional: Override default super admin credentials
# ADMIN_EMAIL=admin@yourdomain.com
# ADMIN_PASSWORD=YourSecurePassword123!
