rules_version = '2';

// Firebase Storage Security Rules
service firebase.storage {
  match /b/{bucket}/o {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Emergency report photos - stored in emergencies/photos/
    match /emergencies/photos/{photoId} {
      // Allow authenticated users to upload photos for emergency reports
      allow write: if isAuthenticated() 
                   && request.resource.size < 10 * 1024 * 1024  // 10MB max file size
                   && request.resource.contentType.matches('image/.*');
      
      // Allow authenticated users to read photos (for viewing in app)
      allow read: if isAuthenticated();
    }
    
    // Default: deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

