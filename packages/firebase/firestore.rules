rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Helper function to check if user is the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // Helper function to check if user is a command center user
    function isCommandCenter() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/commandCenters/$(request.auth.uid));
    }
    
    // Helper function to check if user is a dispatcher
    function isDispatcher() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/dispatchers/$(request.auth.uid));
    }
    
    // Helper function to check if user is a super admin
    function isSuperAdmin() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Admins collection - only super admins can read (used for auth check)
    match /admins/{userId} {
      allow read: if isOwner(userId) || isSuperAdmin();
      allow create, update, delete: if isSuperAdmin();
    }
    
    // Users collection - users can read/update their own profile
    match /users/{userId} {
      allow read: if isOwner(userId) || isCommandCenter() || isDispatcher() || isSuperAdmin();
      allow create: if (isAuthenticated() && isOwner(userId)) || isSuperAdmin();
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isOwner(userId) || isSuperAdmin();
    }
    
    // Dispatchers collection - dispatchers can read their own, command center can read all
    match /dispatchers/{userId} {
      // Allow reading individual dispatcher documents and collection queries
      // Command center can read all dispatchers (needed for getAllDispatchers query)
      allow read: if isOwner(userId) || isCommandCenter() || isSuperAdmin();
      allow create: if (isAuthenticated() && isOwner(userId)) || isSuperAdmin();
      allow update: if isOwner(userId) || isCommandCenter() || isSuperAdmin();
      allow delete: if isCommandCenter() || isSuperAdmin();
    }
    
    // Command Centers collection - command centers can read their own
    match /commandCenters/{userId} {
      allow read: if isOwner(userId) || isCommandCenter() || isSuperAdmin();
      allow create: if (isAuthenticated() && isOwner(userId)) || isSuperAdmin();
      allow update: if isOwner(userId) || isSuperAdmin();
      allow delete: if isOwner(userId) || isSuperAdmin();
    }
    
    // Footage requests (civilian submit; command center / dispatchers manage status)
    match /footageRequests/{requestId} {
      allow create: if isAuthenticated() &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.keys().hasAll([
          'userId', 'purpose', 'purposeOtherText', 'locationText', 'notes',
          'incidentDate', 'status', 'createdAt', 'updatedAt'
        ]);

      allow read: if isAuthenticated() && (
        resource.data.userId == request.auth.uid ||
        isCommandCenter() ||
        isDispatcher()
      );

      allow update: if isAuthenticated() && (isCommandCenter() || isDispatcher());

      allow delete: if isCommandCenter();
    }

    // Emergency Reports collection
    match /emergencies/{reportId} {
      function isEmergencyOwner() {
        return isAuthenticated() && resource.data.userId == request.auth.uid;
      }

      function isCivilianAdditionalDetailsUpdate() {
        return isEmergencyOwner() &&
          request.resource.data.userId == resource.data.userId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'additionalDetails',
            'additionalDetailsSubmittedAt',
            'updatedAt'
          ]);
      }

      // Anyone authenticated can create an emergency report
      allow create: if isAuthenticated() && 
                       request.resource.data.userId == request.auth.uid &&
                       request.resource.data.keys().hasAll(['userId', 'incidentType', 'locationText', 'status', 'createdAt']);
      
      // Allow authenticated users to read all emergency reports
      // This is appropriate for a command center dashboard where authenticated users should see all emergencies
      // Dispatchers can query by dispatcherId to see only their assigned emergencies
      allow read: if isAuthenticated();
      
      // Command center and dispatchers can update reports freely.
      // Civilians can only submit additional detail payloads for their own report.
      allow update: if isAuthenticated() && 
                      (isCommandCenter() || isDispatcher() || isCivilianAdditionalDetailsUpdate());
      
      // Only command center can delete reports
      allow delete: if isCommandCenter();
    }

    // Incident type rules (managed configuration)
    match /incidentTypeRules/{ruleId} {
      // Command centers (and super admins) can read the catalog used for routing.
      allow read: if isCommandCenter() || isSuperAdmin();

      // Only super admins can change the rule catalog.
      allow create, update, delete: if isSuperAdmin();
    }

    // Incidents created by command centers
    match /incidents/{incidentId} {
      // Only command centers can create incidents, and only inside their own namespace.
      allow create: if isAuthenticated()
        && isCommandCenter()
        && request.resource.data.commandCenterAdminId == request.auth.uid;

      // Command centers can read and update only their own incidents.
      allow read: if isSuperAdmin()
        || (isCommandCenter() && resource.data.commandCenterAdminId == request.auth.uid);

      allow update: if isSuperAdmin()
        || (isCommandCenter() && resource.data.commandCenterAdminId == request.auth.uid);

      // Deletes are restricted; keep default deny for now.
      allow delete: if false;
    }

    // Resources collection
    match /resources/{resourceId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (isCommandCenter() || isDispatcher());
    }

    // Teams collection - shared operational team definitions
    match /teams/{teamId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isAuthenticated() && (isCommandCenter() || isSuperAdmin());
    }
    
    // Default: deny all other access
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

